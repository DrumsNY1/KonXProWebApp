@page "/permit-intel/search"
@attribute [Authorize]
@using KonXProWebApp.Models.db_9f8bee_konxdev
@using KonXProWebApp.Models.PermitIntel

<PageTitle>Permit Search — NYC Permit Intel</PageTitle>

<!-- PAGE HEADER -->
<div class="page-header">
    <h1>Permit Feed</h1>
    <p>@($"{totalCount:N0}") new permits matching your criteria · Last updated just now</p>
</div>

<!-- STATS CARDS -->
<div class="stats-row">
    <div class="stat-card">
        <div class="stat-label-sm">⚡ New Leads Today</div>
        <div class="stat-value">@($"{totalCount:N0}")</div>
        <div class="stat-change up">↑ +12 vs yesterday</div>
    </div>
    <div class="stat-card">
        <div class="stat-label-sm">📋 Active Permits</div>
        <div class="stat-value">1,284</div>
        <div class="stat-change up">↑ +89 this week</div>
    </div>
    <div class="stat-card">
        <div class="stat-label-sm">💰 Est. Job Value</div>
        <div class="stat-value text-h2">$8.4M</div>
        <div class="stat-change up">↑ in active permits</div>
    </div>
    <div class="stat-card">
        <div class="stat-label-sm">📌 My Pipeline</div>
        <div class="stat-value">12</div>
        <div class="stat-change neutral">leads being tracked</div>
    </div>
</div>

<div class="card rz-mb-4">
    <div class="card-header">
        <div>
            <div class="card-title">Live Permit Feed</div>
            <div class="card-subtitle">Filter by Borough, Type, and Date</div>
        </div>
        <div class="card-actions">
            <RadzenButton Text="Search" Icon="search" ButtonStyle="Radzen.ButtonStyle.Primary" Size="Radzen.ButtonSize.Small" Click="@SearchPermits" />
            <RadzenButton Text="Export CSV" Icon="get_app" ButtonStyle="Radzen.ButtonStyle.Light" Size="Radzen.ButtonSize.Small" Click="@(async args => await ExportClick(new RadzenSplitButtonItem() { Value = "csv" }))" />
        </div>
    </div>
    <div class="rz-p-4">
        <RadzenRow Gap="1rem">
            <RadzenColumn Size="12" SizeMD="3">
                <RadzenLabel Text="Borough" Component="ddBorough" class="rz-mb-1 rz-display-block" />
                <RadzenDropDown @ref="boroughDropDown" @bind-Value="selectedBoroughs" Data="boroughOptions" Multiple="true"
                                Placeholder="All Boroughs" Style="width: 100%;" Name="ddBorough"
                                Change="@(args => OnFilterChanged())">
                    <FooterTemplate>
                        <RadzenButton Text="Close" Click="@(() => boroughDropDown.ClosePopup())" Size="Radzen.ButtonSize.Small" ButtonStyle="Radzen.ButtonStyle.Light" class="rz-w-100" />
                    </FooterTemplate>
                </RadzenDropDown>
            </RadzenColumn>
            <RadzenColumn Size="12" SizeMD="3">
                <RadzenLabel Text="Job Type" Component="ddJobType" class="rz-mb-1 rz-display-block" />
                <RadzenDropDown @ref="jobTypeDropDown" @bind-Value="selectedJobTypes" Data="jobTypeOptions" Multiple="true"
                                Placeholder="All Types" Style="width: 100%;" Name="ddJobType"
                                TextProperty="Text" ValueProperty="Value"
                                Change="@(args => OnFilterChanged())">
                    <FooterTemplate>
                        <RadzenButton Text="Close" Click="@(() => jobTypeDropDown.ClosePopup())" Size="Radzen.ButtonSize.Small" ButtonStyle="Radzen.ButtonStyle.Light" class="rz-w-100" />
                    </FooterTemplate>
                </RadzenDropDown>
            </RadzenColumn>
            <RadzenColumn Size="12" SizeMD="3">
                <RadzenLabel Text="Date From" Component="dpFrom" class="rz-mb-1 rz-display-block" />
                <RadzenDatePicker @bind-Value="dateFrom" Style="width: 100%;" Name="dpFrom"
                                  DateFormat="MM/dd/yyyy" Change="@(args => OnFilterChanged())" />
            </RadzenColumn>
            <RadzenColumn Size="12" SizeMD="3">
                <RadzenLabel Text="Date To" Component="dpTo" class="rz-mb-1 rz-display-block" />
                <RadzenDatePicker @bind-Value="dateTo" Style="width: 100%;" Name="dpTo"
                                  DateFormat="MM/dd/yyyy" Change="@(args => OnFilterChanged())" />
            </RadzenColumn>
        </RadzenRow>
        
        <RadzenRow class="rz-mt-4" Gap="1rem">
            <RadzenColumn Size="12" SizeMD="3">
                <RadzenLabel Text="Min Cost ($)" Component="numMin" class="rz-mb-1 rz-display-block" />
                <RadzenNumeric @bind-Value="minCost" Style="width: 100%;" Name="numMin"
                               Placeholder="0" Format="N0" Change="@((decimal? args) => OnFilterChanged())" />
            </RadzenColumn>
            <RadzenColumn Size="12" SizeMD="3">
                <RadzenLabel Text="Max Cost ($)" Component="numMax" class="rz-mb-1 rz-display-block" />
                <RadzenNumeric @bind-Value="maxCost" Style="width: 100%;" Name="numMax"
                               Placeholder="No limit" Format="N0" Change="@((decimal? args) => OnFilterChanged())" />
            </RadzenColumn>
            <RadzenColumn Size="12" SizeMD="6">
                <RadzenLabel Text="Trades" class="rz-mb-1 rz-display-block" />
                <RadzenStack Orientation="Radzen.Orientation.Horizontal" Wrap="Radzen.FlexWrap.Wrap" Gap="0.5rem">
                    @foreach (var trade in tradeOptions)
                    {
                        <RadzenToggleButton @bind-Value="trade.Selected" Text="@trade.Name"
                                             ButtonStyle="Radzen.ButtonStyle.Info" Size="Radzen.ButtonSize.Small"
                                             ToggleButtonStyle="Radzen.ButtonStyle.Light"
                                             Change="@(args => OnFilterChanged())" />
                    }
                </RadzenStack>
            </RadzenColumn>
        </RadzenRow>
    </div>

    @* Results Grid *@
    <RadzenDataGrid @ref="grid0" Data="@permits" TItem="DobjobFiling"
                    AllowSorting="true" AllowPaging="true" PageSize="25"
                    ShowPagingSummary="true" PagerHorizontalAlign="Radzen.HorizontalAlign.Center"
                    AllowColumnResize="true" ColumnWidth="180px"
                    Style="min-height: 400px;" class="rz-border-top">
        <Columns>
            <RadzenDataGridColumn TItem="DobjobFiling" Title="Permit #" Width="120px">
                <Template Context="filing">
                    <span class="permit-num">@filing.JobNum</span>
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="DobjobFiling" Title="Address" Width="250px">
                <Template Context="filing">
                    <span class="permit-addr">@filing.HouseNum @filing.StreetName<span class="text-truncate">@filing.JobDescription</span></span>
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="DobjobFiling" Property="Borough" Title="Borough" Width="100px" />
            <RadzenDataGridColumn TItem="DobjobFiling" Title="Trade" Width="100px">
                <Template Context="filing">
                    <span class="trade-tag trade-plumb">@filing.JobType</span>
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="DobjobFiling" Title="Est. Value" Width="110px">
                <Template Context="filing">
                    <span class="value-cell">@filing.InitialCost?.ToString("C0")</span>
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="DobjobFiling" Title="Filed" Width="120px">
                <Template Context="filing">
                    <span class="date-cell">@filing.LatestActionDate?.ToString("MM/dd/yyyy")</span>
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="DobjobFiling" Title="Predictive Score" Width="130px">
                <Template Context="filing">
                    @if (filing.LeadScore.HasValue)
                    {
                        <div class="flex items-center imp-gap-1">
                            @for(int i = 0; i < filing.LeadScore.Value; i++)
                            {
                                <span class="text-accent">🔥</span>
                            }
                            @if(filing.LeadScore.Value >= 4)
                            {
                                <span class="badge badge-danger">HOT</span>
                            }
                        </div>
                    }
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="DobjobFiling" Title="Status" Width="100px">
                <Template Context="filing">
                    <span class="status-badge @(filing.JobStatusDescrp?.Contains("NEW") == true ? "status-new" : "status-hot")">@filing.JobStatusDescrp</span>
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="DobjobFiling" Title="" Width="100px" Sortable="false" Filterable="false">
                <Template Context="filing">
                    <button class="action-btn" @onclick="() => SaveAsLead(filing)">⭐</button>
                    <button class="action-btn" @onclick="() => ViewDetail(filing)">→</button>
                </Template>
            </RadzenDataGridColumn>
        </Columns>
    </RadzenDataGrid>
</div>
