@page "/permit-intel/map"
@attribute [Authorize]
@using KonXProWebApp.Models.db_9f8bee_konxdev
@using KonXProWebApp.Models.PermitIntel

<PageTitle>Permit Map — NYC Permit Intel</PageTitle>

<!-- PAGE HEADER -->
<div class="page-header">
    <h1>Permit Map</h1>
    <p>Visualize active permits across NYC.</p>
</div>

<div class="card rz-mb-4">
    <div class="card-header">
        <div>
            <div class="card-title">Interactive Map</div>
            <div class="card-subtitle">@($"{mapPermitCount:N0} permits currently shown")</div>
        </div>
        <div class="card-actions">
            <RadzenDropDown @bind-Value="selectedBorough" Data="boroughOptions"
                            Placeholder="All Boroughs" Style="width: 200px;"
                            Change="@(args => LoadMapData())" AllowClear="true" />
            <RadzenDropDown @bind-Value="selectedJobType" Data="jobTypeOptions"
                            Placeholder="All Job Types" Style="width: 200px;"
                            Change="@(args => LoadMapData())" AllowClear="true" />
            <RadzenButton Text="Refresh Map" Icon="refresh" ButtonStyle="Radzen.ButtonStyle.Primary" Size="Radzen.ButtonSize.Small" Click="@LoadMapData" />
        </div>
    </div>
    
    @* Map Container *@
    <div id="permit-map" style="height: 600px; width: 100%; border-radius: 0 0 var(--radius) var(--radius); border-top: 1px solid var(--border);"></div>
</div>
