@page "/permit-intel/leads"
@attribute [Authorize]
@using KonXProWebApp.Models.db_9f8bee_konxdev
@using KonXProWebApp.Models.PermitIntel

<PageTitle>My Leads — NYC Permit Intel</PageTitle>

<!-- PAGE HEADER -->
<div class="page-header">
    <h1>My Leads</h1>
    <p>@($"{leads?.Count() ?? 0} saved leads")</p>
</div>

<div class="card rz-mb-4">
    <div class="card-header">
        <div>
            <div class="card-title">Saved Permits</div>
            <div class="card-subtitle">Manage your pipeline</div>
        </div>
        <div class="card-actions">
            @* Status Filter Tabs *@
            <RadzenStack Orientation="Radzen.Orientation.Horizontal" Gap="0.5rem" Wrap="Radzen.FlexWrap.Wrap">
                @foreach (var status in statusOptions)
                {
                    <RadzenButton Text="@($"{status} ({GetStatusCount(status)})")"
                                  ButtonStyle="@(selectedStatus == status ? Radzen.ButtonStyle.Primary : Radzen.ButtonStyle.Light)"
                                  Size="Radzen.ButtonSize.Small"
                                  Click="@(() => FilterByStatus(status))" />
                }
            </RadzenStack>
        </div>
    </div>

    @* Leads Grid *@
    <RadzenDataGrid @ref="grid0" Data="@filteredLeads" TItem="SavedLead"
                    AllowSorting="true" AllowPaging="true" PageSize="20"
                    ShowPagingSummary="true" ColumnWidth="160px"
                    Style="border-top: 1px solid var(--border); border-left: none; border-right: none; border-bottom: none; border-radius: 0 0 var(--radius) var(--radius);">
        <Columns>
            <RadzenDataGridColumn TItem="SavedLead" Title="Score" Width="80px" Sortable="false">
                <Template Context="lead">
                    @if (lead.DobjobFiling != null)
                    {
                        @for (int i = 0; i < (lead.DobjobFiling.LeadScore ?? 1); i++)
                        {
                            <RadzenIcon Icon="star" Style="color: #FFB400; font-size: 14px;" />
                        }
                    }
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="SavedLead" Title="Address" Width="240px">
                <Template Context="lead">
                    @if (lead.DobjobFiling != null)
                    {
                        <RadzenLink Path="@($"/permit-intel/detail/{lead.DobjobFilingId}")"
                                    Text="@($"{lead.DobjobFiling.HouseNum} {lead.DobjobFiling.StreetName}")" />
                    }
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="SavedLead" Title="Borough" Width="120px">
                <Template Context="lead">@(lead.DobjobFiling?.Borough ?? "—")</Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="SavedLead" Title="Est. Cost" Width="120px">
                <Template Context="lead">
                    <span class="value-cell">@(lead.DobjobFiling?.InitialCost?.ToString("C0") ?? "—")</span>
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="SavedLead" Title="Status" Width="140px">
                <Template Context="lead">
                    <RadzenDropDown @bind-Value="lead.Status" Data="leadStatusOptions"
                                    Style="width: 100%;" Change="@(args => UpdateStatus(lead))" />
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="SavedLead" Title="Notes" Width="250px">
                <Template Context="lead">
                    <RadzenTextBox @bind-Value="lead.Notes" Style="width: 100%;" Placeholder="Add notes..."
                                   Change="@(args => UpdateNotes(lead))" />
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="SavedLead" Property="SavedAt" Title="Saved" Width="120px">
                <Template Context="lead">
                    <span class="date-cell">@lead.SavedAt.ToString("MM/dd/yyyy")</span>
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="SavedLead" Title="" Width="60px" Sortable="false">
                <Template Context="lead">
                    <button class="action-btn" @onclick="() => RemoveLead(lead)">🗑️</button>
                </Template>
            </RadzenDataGridColumn>
        </Columns>
    </RadzenDataGrid>
</div>
