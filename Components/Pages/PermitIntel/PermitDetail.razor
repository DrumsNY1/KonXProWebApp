@page "/permit-intel/detail/{Id:int}"
@attribute [Authorize]
@using KonXProWebApp.Models.db_9f8bee_konxdev

<PageTitle>Permit Detail — NYC Permit Intel</PageTitle>

@if (filing == null)
{
    <RadzenRow class="rz-mx-auto rz-px-4" Style="max-width: 1440px;">
        <RadzenColumn Size="12" Style="text-align: center; padding: 4rem 0;">
            <RadzenProgressBarCircular ShowValue="false" Mode="Radzen.ProgressBarMode.Indeterminate" />
        </RadzenColumn>
    </RadzenRow>
}
else
{
    <!-- PAGE HEADER -->
    <div class="page-header">
        <div style="display: flex; justify-content: space-between; align-items: flex-start;">
            <div>
                <h1>@filing.HouseNum @filing.StreetName, @filing.Borough</h1>
                <p>Job #@filing.JobNum · @filing.JobStatusDescrp</p>
            </div>
            <RadzenStack Orientation="Radzen.Orientation.Horizontal" Gap="0.5rem">
                <RadzenButton Text="@(isLeadSaved ? "Saved ★" : "Save Lead")" Icon="@(isLeadSaved ? "star" : "star_border")"
                              ButtonStyle="@(isLeadSaved ? Radzen.ButtonStyle.Warning : Radzen.ButtonStyle.Light)"
                              Click="@ToggleSaveLead" />
                <RadzenButton Text="Back" Icon="arrow_back" ButtonStyle="Radzen.ButtonStyle.Light"
                              Click="@(() => NavigationManager.NavigateTo("/permit-intel/search"))" />
            </RadzenStack>
        </div>
    </div>

    @* Lead Score *@
    <div class="card rz-mb-4">
        <div class="rz-p-4">
            <RadzenStack Orientation="Radzen.Orientation.Horizontal" Gap="2rem" AlignItems="Radzen.AlignItems.Center" Wrap="Radzen.FlexWrap.Wrap">
                <RadzenStack Gap="0.25rem">
                    <RadzenText TextStyle="Radzen.Blazor.TextStyle.Caption" class="rz-text-tertiary-color">Lead Score</RadzenText>
                    <RadzenStack Orientation="Radzen.Orientation.Horizontal" Gap="0">
                        @for (int i = 0; i < (filing.LeadScore ?? 1); i++)
                        {
                            <RadzenIcon Icon="star" Style="color: #FFB400; font-size: 20px;" />
                        }
                        @for (int i = (filing.LeadScore ?? 1); i < 5; i++)
                        {
                            <RadzenIcon Icon="star_border" Style="color: var(--rz-text-tertiary-color); font-size: 20px;" />
                        }
                    </RadzenStack>
                </RadzenStack>
                <RadzenStack Gap="0.25rem">
                    <RadzenText TextStyle="Radzen.Blazor.TextStyle.Caption" class="rz-text-tertiary-color">Estimated Cost</RadzenText>
                    <RadzenText TextStyle="Radzen.Blazor.TextStyle.H5" class="value-cell rz-m-0">@(filing.InitialCost?.ToString("C0") ?? "N/A")</RadzenText>
                </RadzenStack>
                <RadzenStack Gap="0.25rem">
                    <RadzenText TextStyle="Radzen.Blazor.TextStyle.Caption" class="rz-text-tertiary-color">Job Type</RadzenText>
                    <RadzenText TextStyle="Radzen.Blazor.TextStyle.H5" class="rz-m-0">@filing.JobType</RadzenText>
                </RadzenStack>
                <RadzenStack Gap="0.25rem">
                    <RadzenText TextStyle="Radzen.Blazor.TextStyle.Caption" class="rz-text-tertiary-color">Status</RadzenText>
                    <span class="status-badge @(filing.JobStatusDescrp?.Contains("NEW") == true ? "status-new" : "status-hot")">@filing.JobStatusDescrp</span>
                </RadzenStack>
            </RadzenStack>
        </div>
    </div>

    <RadzenRow class="rz-mx-auto rz-mb-4" Style="max-width: 1440px;" Gap="1rem">
        <RadzenColumn Size="12" SizeMD="8">
            <RadzenStack Gap="1rem">
                @* Job Specs *@
                <div class="card">
                    <div class="card-header">
                        <div class="card-title">Job Specifications</div>
                    </div>
                    <div class="rz-p-4">
                        <RadzenText TextStyle="Radzen.Blazor.TextStyle.Body1" class="rz-mb-4">
                            <strong>Description:</strong> @(string.IsNullOrEmpty(filing.JobDescription) ? "No description provided." : filing.JobDescription)
                        </RadzenText>
                        <RadzenRow Gap="1rem">
                            <RadzenColumn Size="6">
                                <RadzenStack Gap="0">
                                    <RadzenText TextStyle="Radzen.Blazor.TextStyle.Caption" class="rz-text-tertiary-color">Block / Lot</RadzenText>
                                    <RadzenText TextStyle="Radzen.Blazor.TextStyle.Body2">@filing.Block / @filing.Lot</RadzenText>
                                </RadzenStack>
                            </RadzenColumn>
                            <RadzenColumn Size="6">
                                <RadzenStack Gap="0">
                                    <RadzenText TextStyle="Radzen.Blazor.TextStyle.Caption" class="rz-text-tertiary-color">BIN</RadzenText>
                                    <RadzenText TextStyle="Radzen.Blazor.TextStyle.Body2">@filing.Bin</RadzenText>
                                </RadzenStack>
                            </RadzenColumn>
                            <RadzenColumn Size="6">
                                <RadzenStack Gap="0">
                                    <RadzenText TextStyle="Radzen.Blazor.TextStyle.Caption" class="rz-text-tertiary-color">Building Class</RadzenText>
                                    <RadzenText TextStyle="Radzen.Blazor.TextStyle.Body2">@filing.Buildingclass</RadzenText>
                                </RadzenStack>
                            </RadzenColumn>
                            <RadzenColumn Size="6">
                                <RadzenStack Gap="0">
                                    <RadzenText TextStyle="Radzen.Blazor.TextStyle.Caption" class="rz-text-tertiary-color">Community Board</RadzenText>
                                    <RadzenText TextStyle="Radzen.Blazor.TextStyle.Body2">@filing.CommunityBoard</RadzenText>
                                </RadzenStack>
                            </RadzenColumn>
                        </RadzenRow>
                    </div>
                </div>

                @* Trades Included *@
                <div class="card">
                    <div class="card-header">
                        <div class="card-title">Trades Included</div>
                    </div>
                    <div class="rz-p-4">
                        <RadzenStack Orientation="Radzen.Orientation.Horizontal" Wrap="Radzen.FlexWrap.Wrap" Gap="0.5rem">
                            @if (filing.Plumbing == "X") { <span class="trade-tag trade-plumb">Plumbing</span> }
                            @if (filing.Mechanical == "X") { <span class="trade-tag trade-hvac">Mechanical</span> }
                            @if (filing.Boiler == "X") { <span class="trade-tag trade-hvac">Boiler</span> }
                            @if (filing.Sprinkler == "X") { <span class="trade-tag trade-plumb">Sprinkler</span> }
                            @if (filing.FireAlarm == "X") { <span class="trade-tag trade-elec">Fire Alarm</span> }
                            @if (filing.Standpipe == "X") { <span class="trade-tag trade-plumb">Standpipe</span> }
                            @if (filing.Equipment == "X") { <span class="trade-tag trade-gc">Equipment</span> }
                            @if (filing.FireSuppression == "X") { <span class="trade-tag trade-plumb">Fire Suppression</span> }
                            @if (filing.CurbCut == "X") { <span class="trade-tag trade-gc">Curb Cut</span> }
                            @if (filing.Other == "X") { <span class="trade-tag trade-gc">Other: @filing.OtherDescription</span> }
                        </RadzenStack>
                    </div>
                </div>
                
                @* Important Dates *@
                <div class="card">
                    <div class="card-header">
                        <div class="card-title">Timeline</div>
                    </div>
                    <div class="rz-p-4">
                        <RadzenRow Gap="1rem">
                            <RadzenColumn Size="4">
                                <RadzenStack Gap="0">
                                    <RadzenText TextStyle="Radzen.Blazor.TextStyle.Caption" class="rz-text-tertiary-color">Pre-Filing</RadzenText>
                                    <RadzenText TextStyle="Radzen.Blazor.TextStyle.Body2">@(filing.PreFilingDate?.ToString("MM/dd/yyyy") ?? "—")</RadzenText>
                                </RadzenStack>
                            </RadzenColumn>
                            <RadzenColumn Size="4">
                                <RadzenStack Gap="0">
                                    <RadzenText TextStyle="Radzen.Blazor.TextStyle.Caption" class="rz-text-tertiary-color">Approved</RadzenText>
                                    <RadzenText TextStyle="Radzen.Blazor.TextStyle.Body2">@(filing.Approved?.ToString("MM/dd/yyyy") ?? "—")</RadzenText>
                                </RadzenStack>
                            </RadzenColumn>
                            <RadzenColumn Size="4">
                                <RadzenStack Gap="0">
                                    <RadzenText TextStyle="Radzen.Blazor.TextStyle.Caption" class="rz-text-tertiary-color">Fully Permitted</RadzenText>
                                    <RadzenText TextStyle="Radzen.Blazor.TextStyle.Body2">@(filing.FullyPermitted?.ToString("MM/dd/yyyy") ?? "—")</RadzenText>
                                </RadzenStack>
                            </RadzenColumn>
                        </RadzenRow>
                    </div>
                </div>
            </RadzenStack>
        </RadzenColumn>

        <RadzenColumn Size="12" SizeMD="4">
            <RadzenStack Gap="1rem">
                @* Contacts & Ownership *@
                <div class="card">
                    <div class="card-header">
                        <div class="card-title">Contacts</div>
                    </div>
                    <div class="rz-p-4">
                        <RadzenStack Gap="1.5rem">
                            <RadzenStack Gap="0">
                                <RadzenText TextStyle="Radzen.Blazor.TextStyle.Caption" class="rz-text-tertiary-color">Owner</RadzenText>
                                <RadzenText TextStyle="Radzen.Blazor.TextStyle.Body1"><strong>@filing.OwnersFirstName @filing.OwnersLastName</strong></RadzenText>
                                <RadzenText TextStyle="Radzen.Blazor.TextStyle.Body2">@filing.OwnersBusinessName</RadzenText>
                                <RadzenText TextStyle="Radzen.Blazor.TextStyle.Body2">@filing.OwnersPhone</RadzenText>
                                <RadzenText TextStyle="Radzen.Blazor.TextStyle.Caption" class="rz-mt-1">@filing.OwnerType</RadzenText>
                            </RadzenStack>
                            <RadzenStack Gap="0">
                                <RadzenText TextStyle="Radzen.Blazor.TextStyle.Caption" class="rz-text-tertiary-color">Applicant / Engineer</RadzenText>
                                <RadzenText TextStyle="Radzen.Blazor.TextStyle.Body1"><strong>@filing.ApplicantsFirstName @filing.ApplicantsLastName</strong></RadzenText>
                                <RadzenText TextStyle="Radzen.Blazor.TextStyle.Body2">@filing.ApplicantProfessionalTitle</RadzenText>
                                <RadzenText TextStyle="Radzen.Blazor.TextStyle.Body2">License: @filing.ApplicantLicenseNum</RadzenText>
                            </RadzenStack>
                        </RadzenStack>
                    </div>
                </div>

                @* Fees *@
                <div class="card">
                    <div class="card-header">
                        <div class="card-title">Fees & Status</div>
                    </div>
                    <div class="rz-p-4">
                        <RadzenRow Gap="1rem">
                            <RadzenColumn Size="6">
                                <RadzenStack Gap="0">
                                    <RadzenText TextStyle="Radzen.Blazor.TextStyle.Caption" class="rz-text-tertiary-color">Total Est. Fee</RadzenText>
                                    <RadzenText TextStyle="Radzen.Blazor.TextStyle.Body2">@(filing.TotalEstFee?.ToString("C2") ?? "—")</RadzenText>
                                </RadzenStack>
                            </RadzenColumn>
                            <RadzenColumn Size="6">
                                <RadzenStack Gap="0">
                                    <RadzenText TextStyle="Radzen.Blazor.TextStyle.Caption" class="rz-text-tertiary-color">Fee Status</RadzenText>
                                    <RadzenBadge Text="@filing.FeeStatus" BadgeStyle="Radzen.BadgeStyle.Info" />
                                </RadzenStack>
                            </RadzenColumn>
                        </RadzenRow>
                    </div>
                </div>
            </RadzenStack>
        </RadzenColumn>
    </RadzenRow>

    @* Violations Section *@
    <RadzenRow class="rz-mx-auto rz-mb-4" Style="max-width: 1440px;" Gap="1rem">
        <RadzenColumn Size="12">
            <div class="card">
                <div class="card-header">
                    <div class="card-title">Building Violations</div>
                </div>
                <div class="rz-p-4">
                    <RadzenTabs>
                        <Tabs>
                            <RadzenTabsItem Text=@($"HPD Open Violations ({hpdViolations.Count()})")>
                                <RadzenDataGrid Data="@hpdViolations" TItem="HpdViolation" AllowPaging="true" PageSize="5" AllowSorting="true">
                                    <Columns>
                                        <RadzenDataGridColumn TItem="HpdViolation" Property="ViolationId" Title="Violation ID" Width="120px" />
                                        <RadzenDataGridColumn TItem="HpdViolation" Property="InspectionDate" Title="Date" FormatString="{0:MM/dd/yyyy}" Width="100px" />
                                        <RadzenDataGridColumn TItem="HpdViolation" Property="Class" Title="Class" Width="80px">
                                            <Template Context="viol">
                                                <RadzenBadge Text="@viol.Class" BadgeStyle="@(viol.Class == "C" ? Radzen.BadgeStyle.Danger : (viol.Class == "B" ? Radzen.BadgeStyle.Warning : Radzen.BadgeStyle.Info))" />
                                            </Template>
                                        </RadzenDataGridColumn>
                                        <RadzenDataGridColumn TItem="HpdViolation" Property="NovDescription" Title="Description" />
                                    </Columns>
                                </RadzenDataGrid>
                            </RadzenTabsItem>
                            <RadzenTabsItem Text=@($"DOB Violations ({dobViolations.Count()})")>
                                <RadzenDataGrid Data="@dobViolations" TItem="DobViolation" AllowPaging="true" PageSize="5" AllowSorting="true">
                                    <Columns>
                                        <RadzenDataGridColumn TItem="DobViolation" Property="ViolationNumber" Title="Number" Width="120px" />
                                        <RadzenDataGridColumn TItem="DobViolation" Property="IssueDate" Title="Date" FormatString="{0:MM/dd/yyyy}" Width="100px" />
                                        <RadzenDataGridColumn TItem="DobViolation" Property="ViolationType" Title="Type" Width="120px" />
                                        <RadzenDataGridColumn TItem="DobViolation" Property="Description" Title="Description" />
                                    </Columns>
                                </RadzenDataGrid>
                            </RadzenTabsItem>
                            <RadzenTabsItem Text=@($"311 Complaints ({complaints311.Count()})")>
                                <RadzenDataGrid Data="@complaints311" TItem="ServiceRequest311" AllowPaging="true" PageSize="5" AllowSorting="true">
                                    <Columns>
                                        <RadzenDataGridColumn TItem="ServiceRequest311" Property="CreatedDate" Title="Date" FormatString="{0:MM/dd/yyyy}" Width="110px" />
                                        <RadzenDataGridColumn TItem="ServiceRequest311" Property="ComplaintType" Title="Type" Width="180px">
                                            <Template Context="c311">
                                                <strong>@c311.ComplaintType</strong>
                                            </Template>
                                        </RadzenDataGridColumn>
                                        <RadzenDataGridColumn TItem="ServiceRequest311" Property="Descriptor" Title="Description" />
                                        <RadzenDataGridColumn TItem="ServiceRequest311" Property="Status" Title="Status" Width="100px">
                                            <Template Context="c311">
                                                <RadzenBadge Text="@c311.Status" BadgeStyle="@(c311.Status == "Closed" ? Radzen.BadgeStyle.Success : Radzen.BadgeStyle.Warning)" />
                                            </Template>
                                        </RadzenDataGridColumn>
                                    </Columns>
                                </RadzenDataGrid>
                            </RadzenTabsItem>
                        </Tabs>
                    </RadzenTabs>
                </div>
            </div>
        </RadzenColumn>
    </RadzenRow>
}
