@page "/admin/contractors"
@layout KonXProWebApp.Components.Layout.MainLayout
@attribute [Microsoft.AspNetCore.Authorization.Authorize]

<PageTitle>Home Improvement Contractors</PageTitle>

<div class="dashboard-container">
    <div class="flex justify-between items-center imp-mb-6">
        <h2>Home Improvement Contractors</h2>
        <RadzenButton Icon="refresh" Text="Refresh" Click="@LoadData" ButtonStyle="ButtonStyle.Secondary" />
    </div>

    @if (isLoading)
    {
        <div class="text-center imp-p-10">
            <RadzenProgressBar Value="100" ShowValue="false" Mode="ProgressBarMode.Indeterminate" />
            <p class="imp-mt-4 text-muted-color">Loading contractors...</p>
        </div>
    }
    else
    {
        <RadzenDataGrid @ref="grid" Data="@contractors" TItem="KonXProWebApp.Models.db_9f8bee_konxdev.HomeImprovementContractor" AllowPaging="true" PageSize="10" AllowSorting="true" AllowFiltering="true" FilterMode="FilterMode.Advanced" LogicalFilterOperator="LogicalFilterOperator.Or" class="modern-grid">
            <Columns>
                <RadzenDataGridColumn TItem="KonXProWebApp.Models.db_9f8bee_konxdev.HomeImprovementContractor" Property="LicenseNumber" Title="License #" Width="120px" />
                <RadzenDataGridColumn TItem="KonXProWebApp.Models.db_9f8bee_konxdev.HomeImprovementContractor" Property="BusinessName" Title="Business Name" />
                <RadzenDataGridColumn TItem="KonXProWebApp.Models.db_9f8bee_konxdev.HomeImprovementContractor" Property="DbaTradeName" Title="DBA/Trade Name" />
                <RadzenDataGridColumn TItem="KonXProWebApp.Models.db_9f8bee_konxdev.HomeImprovementContractor" Property="LicenseStatus" Title="Status" Width="120px">
                    <Template Context="contractor">
                        @if (contractor.LicenseStatus == "Active")
                        {
                            <span class="badge badge-success">Active</span>
                        }
                        else
                        {
                            <span class="badge badge-danger">@contractor.LicenseStatus</span>
                        }
                    </Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="KonXProWebApp.Models.db_9f8bee_konxdev.HomeImprovementContractor" Property="ContactPhoneNumber" Title="Phone" Width="140px" />
                <RadzenDataGridColumn TItem="KonXProWebApp.Models.db_9f8bee_konxdev.HomeImprovementContractor" Property="AddressCity" Title="City" Width="150px" />
                <RadzenDataGridColumn TItem="KonXProWebApp.Models.db_9f8bee_konxdev.HomeImprovementContractor" Property="LicenseExpirationDate" Title="Expiration" FormatString="{0:d}" Width="120px" />
                
                <!-- Expanded address details can be shown, but to keep the grid clean, maybe keep some hidden by default or show AddressStreetName -->
                <RadzenDataGridColumn TItem="KonXProWebApp.Models.db_9f8bee_konxdev.HomeImprovementContractor" Property="AddressStreetName" Title="Street" Visible="false" />
            </Columns>
        </RadzenDataGrid>
    }
</div>

