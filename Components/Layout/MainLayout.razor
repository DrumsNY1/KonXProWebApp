@inherits LayoutComponentBase
<RadzenComponents />

<div class="sidebar">
  <div class="sidebar-logo">
    <div class="logo-icon">K</div>
    <span class="logo-text">Kon<span>X</span>Pro</span>
  </div>

  <nav class="sidebar-nav">
    <div class="nav-section-label">Main</div>
    <a class="nav-item" href="permit-intel/search" Match="NavLinkMatch.Prefix">
      <span class="nav-icon">📋</span> Permit Feed
    </a>
    <a class="nav-item" href="permit-intel/leads">
      <span class="nav-icon">⭐</span> Saved Leads
    </a>
    <a class="nav-item" href="permit-intel/alerts">
      <span class="nav-icon">🔔</span> Alerts
    </a>

    <div class="nav-section-label">Tools</div>
    <a class="nav-item" href="permit-intel/map">
      <span class="nav-icon">🗺️</span> Map
    </a>
    <a class="nav-item" href="permit-intel/dashboard">
      <span class="nav-icon">📊</span> Reports
    </a>

    <div class="nav-section-label">Admin</div>
    <a class="nav-item" href="admin/contractors">
      <span class="nav-icon">👷</span> Contractors
    </a>

    <div class="nav-section-label">Account</div>
    <a class="nav-item" href="Account/Manage">
      <span class="nav-icon">⚙️</span> Settings
    </a>
    <a class="nav-item text-accent" href="permit-intel/subscribe">
      <span class="nav-icon">⚡</span> Upgrade to Pro
    </a>
  </nav>

  <div class="sidebar-upgrade">
    <div class="upgrade-label">⚡ Pro Trial</div>
    <p>7 days left — upgrade to keep unlimited leads and SMS alerts.</p>
    <button class="btn-upgrade" @onclick='() => NavigationManager.NavigateTo("permit-intel/subscribe")'>Upgrade Now — $149/mo</button>
  </div>

  <div class="sidebar-user" @onclick='() => NavigationManager.NavigateTo("Account/Manage")'>
    <div class="user-avatar">US</div>
    <div>
      <div class="user-name">User</div>
      <div class="user-plan">Pro Trial · Plumber</div>
    </div>
  </div>
</div>

<div class="main">
  <!-- TOP BAR -->
  <header class="topbar">
    <div class="topbar-search">
      <span class="text-muted-color">🔍</span>
      <input type="text" placeholder="Search permits, addresses, owners..." @onkeydown="SearchGlobal" />
    </div>
    <div class="topbar-date">@DateTime.Today.ToString("ddd, MMMM d, yyyy")</div>
    <div class="topbar-actions">
      <button class="topbar-btn" @onclick='() => NavigationManager.NavigateTo("permit-intel/map")'>
        🗺
      </button>
      <button class="topbar-btn" @onclick='() => NavigationManager.NavigateTo("permit-intel/alerts")'>
        🔔
      </button>
      <div class="topbar-avatar" @onclick='() => NavigationManager.NavigateTo("Account/Manage")'>US</div>
    </div>
  </header>

  <!-- CONTENT -->
  <div class="content">
    <div class="content-main">
        @Body
    </div>
  </div>
</div>

@code {
    private void SearchGlobal(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            NavigationManager.NavigateTo("permit-intel/search");
        }
    }
}
